rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 通用函數
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidEvaluationScores(scores) {
      return scores.q1 >= 1 && scores.q1 <= 10 &&
        scores.q2 >= 1 && scores.q2 <= 10 &&
        scores.q3 >= 1 && scores.q3 <= 10 &&
        scores.q4 >= 1 && scores.q4 <= 10 &&
        scores.q5 >= 1 && scores.q5 <= 10 &&
        scores.q6 >= 1 && scores.q6 <= 10 &&
        scores.q7 >= 1 && scores.q7 <= 10 &&
        scores.q8 >= 1 && scores.q8 <= 10 &&
        scores.q9 >= 1 && scores.q9 <= 10 &&
        scores.q10 >= 1 && scores.q10 <= 10;
    }

    function isAttendanceLeaveAdjustment(userId) {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['remainingLeaveHours', 'lastAttendanceLeaveAdjustmentId', 'lastAttendanceLeaveAdjustmentBy'])
        && request.resource.data.lastAttendanceLeaveAdjustmentId is string
        && request.resource.data.lastAttendanceLeaveAdjustmentBy == request.auth.uid
        && exists(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId))
        && existsAfter(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId))
        && get(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId)).data.userId == userId
        && getAfter(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId)).data.userId == userId
        && get(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId)).data.type == 4
        && (
          (get(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId)).data.status == 'pending'
            && getAfter(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId)).data.status == 'approved'
            && request.resource.data.remainingLeaveHours == resource.data.remainingLeaveHours
              - get(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId)).data.hours)
          || (get(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId)).data.status == 'approved'
            && getAfter(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId)).data.status == 'pending'
            && request.resource.data.remainingLeaveHours == resource.data.remainingLeaveHours
              + get(/databases/$(database)/documents/attendanceLogs/$(request.resource.data.lastAttendanceLeaveAdjustmentId)).data.hours)
        );
    }

    // 管理員對所有 users 有完全權限；attendance 特休審核可由任一已登入者原子調整對方餘額。
    match /users/{userId}/{document=**} {
      allow read, create: if true

      // 確保 role 欄位沒被修改
      allow update: if
        isSignedIn() &&
        (
          // 管理員可以更新任何欄位
          isAdmin() ||
          // 一般用戶只能更新自己的非敏感資料
          (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email'])) ||
          isAttendanceLeaveAdjustment(userId)
        );
      
      allow delete: if isAdmin();
    }

    match /systemConfig/license {
      allow read, write: if true;
      
      allow update: if
        'maxUsers' in request.resource.data ? isAdmin() : true
    }

    function validAttachmentCount(data) {
      return !('attachments' in data) || (data.attachments is list && data.attachments.size() <= 5);
    }

    // 申請人僅能在自己仍為 pending 的 attendance 申請上編輯內容與附件，
    // 且不得變更 userId 與 status；status 轉換則允許任一已登入者執行。
    function attendanceOwnerEditable(existing, incoming, uid) {
      return existing.userId == uid
        && existing.status == 'pending'
        && incoming.userId == existing.userId
        && incoming.status == existing.status;
    }

    function attendanceStatusEditable(existing, incoming) {
      return incoming.userId == existing.userId
        && incoming.status in ['pending', 'approved', 'rejected']
        && incoming.status != existing.status
        && incoming.diff(existing).affectedKeys().hasOnly(['status']);
    }

    function validAttendanceAuditAction(action) {
      return action in ['create', 'update', '建立', '更新', '新增附件', '刪除附件'];
    }

    function validSubsidyAuditAction(action) {
      return action in ['create', 'update', 'status_change', '建立', '更新', '狀態變更', '新增附件', '刪除附件'];
    }

    function validUploadSessionParent(data) {
      return (data.requestKind == 'attendance'
          && (!exists(/databases/$(database)/documents/attendanceLogs/$(data.requestId))
            || (data.ownerUid == get(/databases/$(database)/documents/attendanceLogs/$(data.requestId)).data.userId
              && (isAdmin()
                || (data.ownerUid == request.auth.uid
                  && get(/databases/$(database)/documents/attendanceLogs/$(data.requestId)).data.status == 'pending')))))
        || (data.requestKind == 'subsidy'
          && (!exists(/databases/$(database)/documents/subsidyApplications/$(data.requestId))
            || (data.ownerUid == get(/databases/$(database)/documents/subsidyApplications/$(data.requestId)).data.userId
              && (isAdmin()
                || (data.ownerUid == request.auth.uid
                  && get(/databases/$(database)/documents/subsidyApplications/$(data.requestId)).data.status == 'pending')))));
    }

    function validCleanupTransfer(data, attachmentId) {
      return data.attachment.id == attachmentId
        && ((data.requestKind == 'attendance'
          && data.ownerUid == get(/databases/$(database)/documents/attendanceLogs/$(data.requestId)).data.userId
          && get(/databases/$(database)/documents/attendanceLogs/$(data.requestId)).data.attachments.hasAny([data.attachment])
          && !getAfter(/databases/$(database)/documents/attendanceLogs/$(data.requestId)).data.attachments.hasAny([data.attachment]))
        || (data.requestKind == 'subsidy'
          && data.ownerUid == get(/databases/$(database)/documents/subsidyApplications/$(data.requestId)).data.userId
          && get(/databases/$(database)/documents/subsidyApplications/$(data.requestId)).data.attachments.hasAny([data.attachment])
          && !getAfter(/databases/$(database)/documents/subsidyApplications/$(data.requestId)).data.attachments.hasAny([data.attachment])));
    }

    match /attendanceLogs/{attendanceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && validAttachmentCount(request.resource.data)
        && (!('attachments' in request.resource.data) || request.resource.data.attachments.size() == 0
          || request.resource.data.userId == request.auth.uid || isAdmin());
      // GitHub issue #34：任一已登入者可變更validJourneyEventAttachmentAt attendance status；內容與附件仍只允許 admin
      // 或「pending 狀態下的申請人本人」更新，避免 status 審核入口順手改動申請內容。
      allow update: if isSignedIn() && validAttachmentCount(request.resource.data)
        && (isAdmin()
          || attendanceOwnerEditable(resource.data, request.resource.data, request.auth.uid)
          || attendanceStatusEditable(resource.data, request.resource.data));
      allow delete: if isAdmin();

      match /auditTrail/{auditId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.actionBy == request.auth.uid
          && validAttendanceAuditAction(request.resource.data.action)
          && (!(request.resource.data.action in ['新增附件', '刪除附件']) || isAdmin()
            || (getAfter(/databases/$(database)/documents/attendanceLogs/$(attendanceId)).data.userId == request.auth.uid
              && getAfter(/databases/$(database)/documents/attendanceLogs/$(attendanceId)).data.status == 'pending'));
        allow update, delete: if false;
      }
    }

    match /attendanceStats/{document=**} {
      allow read, write, update: if true;
    }

    // 統一補助申請集合
    match /subsidyApplications/{applicationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && validAttachmentCount(request.resource.data)
        && (!('attachments' in request.resource.data) || request.resource.data.attachments.size() == 0
          || request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.userId == request.auth.uid &&
         resource.data.status == 'pending' &&
         request.resource.data.userId == resource.data.userId &&
         request.resource.data.status == resource.data.status)
      ) && validAttachmentCount(request.resource.data);
      allow delete: if isAdmin();

      // 筆電分期子集合
      match /installments/{installmentId} {
        allow read: if isSignedIn();
        allow create: if isAdmin();
      }

      // 稽核軌跡子集合
      match /auditTrail/{auditId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.actionBy == request.auth.uid
          && validSubsidyAuditAction(request.resource.data.action)
          && (!(request.resource.data.action in ['新增附件', '刪除附件']) || isAdmin()
            || (getAfter(/databases/$(database)/documents/subsidyApplications/$(applicationId)).data.userId == request.auth.uid
              && getAfter(/databases/$(database)/documents/subsidyApplications/$(applicationId)).data.status == 'pending'));
        allow update, delete: if false;
      }
    }

    match /requestAttachmentUploadSessions/{sessionId} {
      allow create: if isSignedIn()
        && request.resource.data.actorUid == request.auth.uid
        && (request.resource.data.ownerUid == request.auth.uid || isAdmin())
        && validUploadSessionParent(request.resource.data)
        && request.resource.data.status == 'uploading'
        && request.resource.data.plannedAttachments is list
        && request.resource.data.plannedAttachments.size() > 0
        && request.resource.data.plannedAttachments.size() <= 5
        && request.resource.data.plannedPaths is list
        && request.resource.data.plannedPaths.size() == request.resource.data.plannedAttachments.size();
      allow get, delete: if isSignedIn() && (resource.data.actorUid == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow update: if isSignedIn() && (resource.data.actorUid == request.auth.uid || isAdmin())
        && resource.data.status == 'uploading'
        && request.resource.data.actorUid == resource.data.actorUid
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.requestId == resource.data.requestId
        && request.resource.data.status == 'cleanup-pending'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'lastErrorCode']);
    }

    match /requestAttachmentCleanupQueue/{attachmentId} {
      allow create: if isSignedIn() && request.resource.data.actorUid == request.auth.uid
        && validCleanupTransfer(request.resource.data, attachmentId);
      allow get, delete: if isSignedIn() && (resource.data.actorUid == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.actorUid == request.auth.uid || isAdmin())
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['attemptCount', 'lastAttemptAt', 'lastErrorCode']);
      allow list: if isAdmin();
    }

    // =============================================
    // 使用者歷程事件（006-user-journey-timeline）
    // =============================================

    function journeyEventPath(eventId) {
      return /databases/$(database)/documents/userJourneyEvents/$(eventId);
    }

    function validJourneyAudit(data) {
      return data.keys().hasOnly([
          'eventId', 'targetUserId', 'action', 'actorUid', 'actionAt',
          'title', 'changedFields', 'attachmentSummary'
        ])
        && data.keys().hasAll([
          'eventId', 'targetUserId', 'action', 'actorUid', 'actionAt',
          'title', 'changedFields', 'attachmentSummary'
        ])
        && data.eventId is string
        && data.targetUserId is string
        && data.action in ['create', 'update', 'delete']
        && data.actorUid == request.auth.uid
        && data.actionAt is timestamp
        && data.title is string
        && data.changedFields is list
        && data.attachmentSummary is list;
    }

    function validJourneyAuditCreateEffect(data, auditId) {
      return data.action == 'create'
        && isAdmin()
        && auditId is string
        && auditId.size() > 0;
    }

    function validJourneyAuditUpdateEffect(data, auditId) {
      return data.action == 'update'
        && isSignedIn()
        && data.actorUid == request.auth.uid
        && auditId is string
        && auditId.size() > 0;
    }

    function validJourneyAuditDeleteEffect(data, auditId) {
      let path = journeyEventPath(data.eventId);
      return data.action == 'delete'
        && isAdmin()
        && exists(path)
        && auditId == get(path).data.deleteAuditId
        && !existsAfter(path);
    }

    match /userJourneyEvents/{eventId} {
      allow read: if isSignedIn();
      // Production issue #36 mitigation: create/update are intentionally reduced
      // to signed-in actor checks so we can separate Firestore/Auth deployment
      // issues from event schema/admin checks. UI still exposes writes only to
      // Admin users; delete remains Admin-only below.
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && request.resource.data.targetUserId == resource.data.targetUserId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.deleteAuditId == resource.data.deleteAuditId
        && request.resource.data.lastAuditId != resource.data.lastAuditId;
      allow delete: if isAdmin();
    }

    match /userJourneyEventAudits/{auditId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && (
          (validJourneyAudit(request.resource.data)
            && validJourneyAuditCreateEffect(request.resource.data, auditId))
          || validJourneyAuditUpdateEffect(request.resource.data, auditId)
          || (validJourneyAudit(request.resource.data)
            && validJourneyAuditDeleteEffect(request.resource.data, auditId))
        );
      allow update, delete: if false;
    }

    function validJourneySessionParent(data) {
      let path = journeyEventPath(data.eventId);
      return isSignedIn()
        && (!exists(path) || get(path).data.targetUserId == data.targetUserId);
    }

    match /journeyEventAttachmentUploadSessions/{sessionId} {
      allow create: if isSignedIn()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.status == 'uploading'
        && request.resource.data.eventId is string
        && request.resource.data.targetUserId is string
        && request.resource.data.plannedAttachments is list
        && request.resource.data.plannedAttachments.size() > 0
        && request.resource.data.plannedAttachments.size() <= 5
        && request.resource.data.plannedPaths is list
        && request.resource.data.plannedPaths.size() == request.resource.data.plannedAttachments.size()
        && validJourneySessionParent(request.resource.data);
      allow get, delete: if isSignedIn();
      allow list: if isAdmin();
      allow update: if isSignedIn() && (resource.data.actorUid == request.auth.uid || isAdmin())
        && resource.data.status == 'uploading'
        && request.resource.data.actorUid == resource.data.actorUid
        && request.resource.data.eventId == resource.data.eventId
        && request.resource.data.targetUserId == resource.data.targetUserId
        && request.resource.data.status == 'cleanup-pending'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'lastErrorCode']);
    }

    function hasJourneyAttachmentIdAt(data, index, attachmentId) {
      return data.attachments.size() > index
        && data.attachments[index] is map
        && data.attachments[index].keys().hasAny(['id'])
        && data.attachments[index].id == attachmentId;
    }

    function hasJourneyAttachmentStoragePathAt(data, index, storagePath) {
      return data.attachments.size() > index
        && data.attachments[index] is map
        && data.attachments[index].keys().hasAny(['storagePath'])
        && data.attachments[index].storagePath == storagePath;
    }

    function hasJourneyAttachmentAt(data, index, attachmentId, storagePath) {
      return hasJourneyAttachmentStoragePathAt(data, index, storagePath)
        && (!data.attachments[index].keys().hasAny(['id']) || data.attachments[index].id == attachmentId);
    }

    function hasJourneyAttachment(data, attachmentId, storagePath) {
      return data.attachments is list
        && (
          hasJourneyAttachmentAt(data, 0, attachmentId, storagePath)
          || hasJourneyAttachmentAt(data, 1, attachmentId, storagePath)
          || hasJourneyAttachmentAt(data, 2, attachmentId, storagePath)
          || hasJourneyAttachmentAt(data, 3, attachmentId, storagePath)
          || hasJourneyAttachmentAt(data, 4, attachmentId, storagePath)
        );
    }

    function hasJourneyAttachmentId(data, attachmentId) {
      return data.attachments is list
        && (
          hasJourneyAttachmentIdAt(data, 0, attachmentId)
          || hasJourneyAttachmentIdAt(data, 1, attachmentId)
          || hasJourneyAttachmentIdAt(data, 2, attachmentId)
          || hasJourneyAttachmentIdAt(data, 3, attachmentId)
          || hasJourneyAttachmentIdAt(data, 4, attachmentId)
        );
    }

    function hasJourneyAttachmentStoragePath(data, storagePath) {
      return data.attachments is list
        && (
          hasJourneyAttachmentStoragePathAt(data, 0, storagePath)
          || hasJourneyAttachmentStoragePathAt(data, 1, storagePath)
          || hasJourneyAttachmentStoragePathAt(data, 2, storagePath)
          || hasJourneyAttachmentStoragePathAt(data, 3, storagePath)
          || hasJourneyAttachmentStoragePathAt(data, 4, storagePath)
        );
    }

    function validJourneyCleanupTransfer(data, attachmentId) {
      let path = journeyEventPath(data.eventId);
      return data.attachment.id == attachmentId
        && data.attachment.storagePath is string
        && data.attachment.storagePath.matches(
          '^journey-event-attachments/' + data.targetUserId + '/' + data.eventId + '/[^/]+/' + attachmentId + '$'
        )
        && exists(path)
        && get(path).data.targetUserId == data.targetUserId
        && hasJourneyAttachment(get(path).data, attachmentId, data.attachment.storagePath)
        && (!existsAfter(path)
          || (!hasJourneyAttachmentId(getAfter(path).data, attachmentId)
            && !hasJourneyAttachmentStoragePath(getAfter(path).data, data.attachment.storagePath)));
    }

    match /journeyEventAttachmentCleanupQueue/{attachmentId} {
      allow create: if isSignedIn()
        && request.resource.data.actorUid == request.auth.uid
        && validJourneyCleanupTransfer(request.resource.data, attachmentId);
      // delete 只能在 Storage 物件已完成清理後由 service 執行；Rules 無法反查 Storage 狀態。
      // issue #36 production mitigation：以原 actor ownership 清理 queue，避免 admin role 讀取差異阻斷附件更新。
      allow get: if isSignedIn() && (resource.data.actorUid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && resource.data.actorUid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.actorUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['attemptCount', 'lastAttemptAt', 'lastErrorCode']);
      allow list: if isAdmin();
    }

    // 供餐補助集合（原始資料）
    match /mealSubsidies/{dateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 使用者月度餐費統計
    match /userMealStats/{statsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 補助統計
    match /subsidyStats/{statsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // =============================================
    // 評量考核系統（002-peer-evaluation）
    // =============================================

    // 考核週期：所有已登入使用者可讀，僅管理者可寫
    // 隨機快選儲存時，管理者可在 transaction 中更新 totalAssignments。
    // 例外：一般使用者提交考評時可遞增 completedAssignments（原子性加一）
    match /evaluationCycles/{cycleId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (isSignedIn() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completedAssignments']));
    }

    // 評核指派：評核者讀自己的指派 or 管理者；隨機快選與手動建立/刪除僅管理者；更新評核者自己 or 管理者
    match /evaluationAssignments/{assignmentId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.evaluatorUid == request.auth.uid);

      allow create: if isAdmin();

      allow update: if isAdmin() ||
        (isSignedIn() &&
         resource.data.evaluatorUid == request.auth.uid &&
         request.resource.data.evaluatorUid == resource.data.evaluatorUid &&
         request.resource.data.evaluateeUid == resource.data.evaluateeUid &&
         request.resource.data.cycleId == resource.data.cycleId);

      allow delete: if isAdmin();
    }

    // ⚠️ 評核表單：匿名性關鍵集合
    // 受評者（evaluateeUid == request.auth.uid）完全無法讀取，確保評核者身份匿名
    match /evaluationForms/{formId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.evaluatorUid == request.auth.uid);

      allow create: if isSignedIn() &&
        request.resource.data.evaluatorUid == request.auth.uid &&
        // 確保 10 道題分數值在合法範圍（1–10）
        isValidEvaluationScores(request.resource.data.scores) &&
        // 確保整體評價字數在範圍內（20–500 字）
        request.resource.data.overallComment.size() >= 20 &&
        request.resource.data.overallComment.size() <= 500;

      // 管理者可更新；評核者可在截止日前更新自己提交的表單（不可改身分與關聯欄位）
      allow update: if isAdmin() ||
        (isSignedIn() &&
         resource.data.evaluatorUid == request.auth.uid &&
         request.resource.data.evaluatorUid == resource.data.evaluatorUid &&
         request.resource.data.evaluateeUid == resource.data.evaluateeUid &&
         request.resource.data.cycleId == resource.data.cycleId &&
         request.resource.data.assignmentId == resource.data.assignmentId &&
         request.resource.data.anomalyFlags == resource.data.anomalyFlags &&
         isValidEvaluationScores(request.resource.data.scores) &&
         request.resource.data.overallComment.size() >= 20 &&
         request.resource.data.overallComment.size() <= 500 &&
         exists(/databases/$(database)/documents/evaluationCycles/$(resource.data.cycleId)) &&
         get(/databases/$(database)/documents/evaluationCycles/$(resource.data.cycleId)).data.deadline > request.time);

      // 禁止任何人刪除考評表（資料完整性）
      allow delete: if false;
    }

    // 使用者屬性快照：受評者讀自己 or 管理者；寫入限管理者或評核者（僅 preview 狀態）
    match /userAttributeSnapshots/{snapshotId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);

      // 管理者可隨時建立；評核者只能建立 preview 狀態（不能建立自己的快照）
      allow create: if isAdmin() ||
        (isSignedIn() &&
         request.resource.data.status == 'preview' &&
         request.resource.data.userId != request.auth.uid);

      // 管理者可隨時更新；評核者只能更新 preview → preview（不能升格為 final，不能更換受評者或週期）
      allow update: if isAdmin() ||
        (isSignedIn() &&
         resource.data.status == 'preview' &&
         request.resource.data.status == 'preview' &&
         request.resource.data.userId == resource.data.userId &&
         request.resource.data.cycleId == resource.data.cycleId &&
         resource.data.userId != request.auth.uid);

      // 禁止刪除（歷史快照永久保留）
      allow delete: if false;
    }
  }
}
