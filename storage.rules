rules_version = '2';

// Firebase Storage 安全規則
// 路徑慣例：avatars/{uid}/avatar.webp（確定性路徑，新圖覆寫舊圖）
service firebase.storage {
  match /b/{bucket}/o {
    // 是否為 admin：跨服務讀取 Firestore users/{uid}.role（每次計費一次 read）
    function isAdmin() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /avatars/{uid}/{fileName} {
      // 僅登入者可讀
      allow read: if request.auth != null;

      // 本人或 admin 可寫；限圖片、限大小（< 1MB）
      allow write: if request.auth != null
        && (request.auth.uid == uid || isAdmin())
        && request.resource.size < 1 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // 本人或 admin 可刪（離職清理由 admin 或稽核腳本處理）
      allow delete: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
    }

    function isAllowedAttachmentType() {
      return request.resource.contentType == 'application/pdf'
        || request.resource.contentType == 'image/jpeg'
        || request.resource.contentType == 'image/png'
        || request.resource.contentType == 'image/webp';
    }

    function hasValidUploadSession(kind, requestId, sessionId, attachmentId) {
      let session = firestore.get(/databases/(default)/documents/requestAttachmentUploadSessions/$(sessionId)).data;
      return session.status == 'uploading'
        && session.actorUid == request.auth.uid
        && session.requestKind == kind
        && session.requestId == requestId
        && request.resource.metadata.ownerUid == session.ownerUid
        && session.plannedPaths.hasAny([
          'request-attachments/' + kind + '/' + requestId + '/' + sessionId + '/' + attachmentId
        ]);
    }

    function ownsUploadSessionPath(kind, requestId, sessionId, attachmentId) {
      let session = firestore.get(/databases/(default)/documents/requestAttachmentUploadSessions/$(sessionId)).data;
      return session.actorUid == request.auth.uid
        && session.status in ['uploading', 'cleanup-pending']
        && session.requestKind == kind
        && session.requestId == requestId
        && resource.metadata.ownerUid == session.ownerUid
        && session.plannedPaths.hasAny([
          'request-attachments/' + kind + '/' + requestId + '/' + sessionId + '/' + attachmentId
        ]);
    }

    function hasCleanupOwnership(attachmentId) {
      let queuePath = /databases/(default)/documents/requestAttachmentCleanupQueue/$(attachmentId);
      // exists guard 會多一次 rules read，但可避免 Storage Rules 對缺失 cleanup queue 的 get(...).data 產生 null evaluation warning。
      return firestore.exists(queuePath)
        && 'actorUid' in firestore.get(queuePath).data
        && firestore.get(queuePath).data.actorUid == request.auth.uid;
    }

    match /request-attachments/{kind}/{requestId}/{sessionId}/{attachmentId} {
      allow get: if request.auth != null;
      allow list: if false;

      allow create: if resource == null
        && request.auth != null
        && (kind == 'attendance' || kind == 'subsidy')
        && request.resource.size > 0
        && request.resource.size <= 3 * 1024 * 1024
        && isAllowedAttachmentType()
        && request.resource.metadata.requestKind == kind
        && request.resource.metadata.requestId == requestId
        && request.resource.metadata.attachmentId == attachmentId
        && request.resource.metadata.uploadedBy == request.auth.uid
        && hasValidUploadSession(kind, requestId, sessionId, attachmentId);

      allow update: if false;

      allow delete: if request.auth != null && (
        isAdmin()
        || ownsUploadSessionPath(kind, requestId, sessionId, attachmentId)
        || hasCleanupOwnership(attachmentId)
      );
    }

    function hasValidJourneyUploadSession(targetUserId, eventId, sessionId, attachmentId) {
      let session = firestore.get(/databases/(default)/documents/journeyEventAttachmentUploadSessions/$(sessionId)).data;
      return session.status == 'uploading'
        && session.actorUid == request.auth.uid
        && session.targetUserId == targetUserId
        && session.eventId == eventId
        && request.resource.metadata.targetUserId == targetUserId
        && request.resource.metadata.eventId == eventId
        && session.plannedPaths.hasAny([
          'journey-event-attachments/' + targetUserId + '/' + eventId + '/' + sessionId + '/' + attachmentId
        ]);
    }

    function ownsJourneyUploadSession(targetUserId, eventId, sessionId, attachmentId) {
      let sessionPath = /databases/(default)/documents/journeyEventAttachmentUploadSessions/$(sessionId);
      let session = firestore.get(sessionPath).data;
      return session.actorUid == request.auth.uid
        && session.status in ['uploading', 'cleanup-pending']
        && session.targetUserId == targetUserId
        && session.eventId == eventId
        && resource.metadata.targetUserId == targetUserId
        && session.plannedPaths.hasAny([
          'journey-event-attachments/' + targetUserId + '/' + eventId + '/' + sessionId + '/' + attachmentId
        ]);
    }

    function hasJourneyUploadSession(sessionId) {
      return firestore.exists(/databases/(default)/documents/journeyEventAttachmentUploadSessions/$(sessionId));
    }

    function hasJourneyCleanupOwnership(targetUserId, eventId, sessionId, attachmentId) {
      let queuePath = /databases/(default)/documents/journeyEventAttachmentCleanupQueue/$(attachmentId);
      let queue = firestore.get(queuePath).data;
      return queue.actorUid == request.auth.uid
        && queue.eventId == eventId
        && queue.targetUserId == targetUserId
        && queue.attachment.storagePath
          == 'journey-event-attachments/' + targetUserId + '/' + eventId + '/' + sessionId + '/' + attachmentId;
    }

    function hasJourneyCleanupQueue(attachmentId) {
      return firestore.exists(/databases/(default)/documents/journeyEventAttachmentCleanupQueue/$(attachmentId));
    }

    match /journey-event-attachments/{targetUserId}/{eventId}/{sessionId}/{attachmentId} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if resource == null
        && request.auth != null
        && request.resource.size > 0
        && request.resource.size <= 3 * 1024 * 1024
        && isAllowedAttachmentType()
        && request.resource.metadata.attachmentId == attachmentId
        && request.resource.metadata.uploadedBy == request.auth.uid
        && hasJourneyUploadSession(sessionId)
        && hasValidJourneyUploadSession(targetUserId, eventId, sessionId, attachmentId);
      allow update: if false;
      // 刪除必須由 upload session 或 cleanup queue 治理；Admin 不可繞過 Firestore 事件附件關聯直接刪除 Storage 物件。
      // exists guard 會多一次 rules read，但可避免 Storage Rules 對缺失文件 get(...).data 產生 null evaluation warning。
      allow delete: if request.auth != null && (
        (hasJourneyUploadSession(sessionId) && ownsJourneyUploadSession(targetUserId, eventId, sessionId, attachmentId))
        || (hasJourneyCleanupQueue(attachmentId) && hasJourneyCleanupOwnership(targetUserId, eventId, sessionId, attachmentId))
      );
    }

    // 其餘路徑一律拒絕
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
